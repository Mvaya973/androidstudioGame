<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="8dp">

    <!-- Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="16dp"
        android:background="@color/bg_display">

        <TextView
            android:id="@+id/display_expr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:gravity="end"
            android:maxLines="1"
            android:ellipsize="start"
            android:text="" />

        <TextView
            android:id="@+id/display_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="56sp"
            android:textColor="@color/text_primary"
            android:gravity="end"
            android:maxLines="1"
            android:ellipsize="start"
            android:text="0" />
    </LinearLayout>

    <!-- Buttons -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="4dp">

        <!-- Row 1: AC, +/-, %, ÷ -->
        <Button android:id="@+id/btn_clear"   style="@style/FuncBtn"  android:text="AC"  android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_sign"    style="@style/FuncBtn"  android:text="+/-" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_percent" style="@style/FuncBtn"  android:text="%"   android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_div"     style="@style/OpBtn"    android:text="÷"   android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>

        <!-- Row 2: 7, 8, 9, × -->
        <Button android:id="@+id/btn_7" style="@style/NumBtn" android:text="7" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_8" style="@style/NumBtn" android:text="8" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_9" style="@style/NumBtn" android:text="9" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_mul" style="@style/OpBtn" android:text="×" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>

        <!-- Row 3: 4, 5, 6, - -->
        <Button android:id="@+id/btn_4" style="@style/NumBtn" android:text="4" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_5" style="@style/NumBtn" android:text="5" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_6" style="@style/NumBtn" android:text="6" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_sub" style="@style/OpBtn" android:text="-" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>

        <!-- Row 4: 1, 2, 3, + -->
        <Button android:id="@+id/btn_1" style="@style/NumBtn" android:text="1" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_2" style="@style/NumBtn" android:text="2" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_3" style="@style/NumBtn" android:text="3" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_add" style="@style/OpBtn" android:text="+" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>

        <!-- Row 5: ⌫, 0, ., = -->
        <Button android:id="@+id/btn_del" style="@style/FuncBtn" android:text="⌫" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_0"   style="@style/NumBtn" android:text="0" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_dot" style="@style/NumBtn" android:text="." android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>
        <Button android:id="@+id/btn_equal" style="@style/EqBtn" android:text="=" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_width="0dp" android:layout_height="0dp"/>

    </GridLayout>
</LinearLayout>
